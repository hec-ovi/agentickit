# Pick ONE provider.
#
# vLLM (local, OpenAI-compatible at /v1):
OPENAI_API_KEY=dummy-vllm-ignores-this
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
PILOT_MODEL=openai/gpt-oss-120b

# Or a hosted provider:
# OPENAI_API_KEY=sk-...
# PILOT_MODEL=openai/gpt-4o-mini

# Server port (API route). The Vite dev server proxies /api to this.
PORT=8787
