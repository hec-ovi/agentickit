# ---------------------------------------------------------------------------
# agentickit todo example — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in a key. Only ONE of the options
# below is required — the agentickit handler uses Vercel AI Gateway model
# strings (e.g. "openai/gpt-4o", "anthropic/claude-sonnet-4-5", "groq/...").
# ---------------------------------------------------------------------------

# Primary (recommended): Vercel AI Gateway. Works with any provider prefix.
# Get one at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Fallback: when deploying to Vercel with OIDC linked, no key is required.
# VERCEL_OIDC_TOKEN is injected automatically by the platform.
