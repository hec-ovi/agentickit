# ---------------------------------------------------------------------------
# agentickit todo example — environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and pick ONE of the options below. The
# handler auto-detects which provider key is present and routes through the
# matching `@ai-sdk/*` adapter; if none is found it falls back to the
# Vercel AI Gateway when AI_GATEWAY_API_KEY is set.
# ---------------------------------------------------------------------------

# --- Recommended: OpenRouter free tier (no credit card) ---------------------
# Sign up at https://openrouter.ai/keys — the example route defaults to a
# free model that supports tool calling (qwen/qwen3-coder:free).
OPENROUTER_API_KEY=sk-or-v1-...

# --- Alternative: direct provider keys --------------------------------------
# Uncomment the one you want to use. Credit card required for OpenAI,
# Anthropic, Google, Mistral; Groq has a generous free tier too.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# MISTRAL_API_KEY=...

# --- Alternative: Vercel AI Gateway -----------------------------------------
# Works with any prefix (openai/*, anthropic/*, groq/*, etc.). On Vercel
# deployments VERCEL_OIDC_TOKEN is injected automatically.
# AI_GATEWAY_API_KEY=...
