{
  "name": "agentickit-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo root for agentickit — React hooks + UI for AI copilots. AI SDK 6 native.",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm -r --filter \"./packages/*\" --parallel dev",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
